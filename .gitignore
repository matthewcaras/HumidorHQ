# Filename: .gitignore
# Revision: 1.2.0
# Description: Git ignore rules for local secrets, runtime artifacts, and tooling output.
# Modified Date: 2026-07-18 13:15 ET

# Logs and local diagnostics
logs/
*.log

# Local environment and secrets
.env
.env.*
*.local
/data/auth-users.json
/data/audit-log.jsonl
/data/catalog-cigars.json
/data/vendors.json
/data/storage-locations.json
/data/storage-sub-locations.json
/data/purchases.json
/data/purchase-lines.json
/data/lots.json
/data/lot-location-balances.json
/data/inventory-events.json
/data/smoking-journal-entries.json
/data/counters.json

# PHP and flat-file runtime artifacts
/data/*.lock
/data/*.tmp
/data/*.tmp.*
/runtime-data/
/.runtime-data/

# Optional local tooling folders
vendor/
node_modules/
dist/

# Editor and OS files
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Per-computer Codex capability check state
.codex-local/*
!.codex-local/tool-check.json.placeholder
