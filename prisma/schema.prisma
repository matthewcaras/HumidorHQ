generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum StorageOrganizationType {
  GENERAL
  DRAWERS
  SHELVES
  CUSTOM
}

enum StorageSubLocationKind {
  GENERAL
  DRAWER
  SHELF
  CUSTOM
}

model StorageLocation {
  id               Int                     @id @default(autoincrement())
  name             String
  capacity         Int?
  notes            String?
  isActive         Boolean                 @default(true)
  displayOrder     Int                     @default(0)
  hasShelves       Boolean                 @default(false)
  shelfCount       Int?
  organizationType StorageOrganizationType @default(GENERAL)
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  lots         Lot[]
  subLocations StorageSubLocation[]
}

model Vendor {
  id        Int      @id @default(autoincrement())
  name      String
  nameKey   String   @unique
  website   String?
  notes     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  purchaseOrders PurchaseOrder[]

  @@index([isActive, nameKey])
}

model Manufacturer {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lines CigarLine[]
}

model CigarLine {
  id             Int      @id @default(autoincrement())
  name           String
  manufacturerId Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  manufacturer Manufacturer @relation(fields: [manufacturerId], references: [id])
  vitolas      Vitola[]
}

model Vitola {
  id        Int      @id @default(autoincrement())
  name      String
  size      String?
  strength  String?
  lineId    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  line CigarLine @relation(fields: [lineId], references: [id])
  lots Lot[]
}

model PurchaseOrder {
  id            Int       @id @default(autoincrement())
  vendorId      Int?
  orderDate     DateTime
  orderNumber   String?
  purchaseDate  DateTime?
  invoiceNumber String?
  shipping      Decimal   @default(0)
  tax           Decimal   @default(0)
  exciseTax     Decimal   @default(0)
  salesTax      Decimal   @default(0)
  discount      Decimal   @default(0)
  totalPaid     Decimal?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  vendor Vendor?        @relation(fields: [vendorId], references: [id])
  lots   Lot[]
  lines  PurchaseLine[]

  @@unique([vendorId, invoiceNumber])
  @@index([vendorId, purchaseDate])
  @@index([purchaseDate])
}

/// receivedDate is line-level so one purchase can support split shipments without a separate shipment model.
model PurchaseLine {
  id                 Int       @id @default(autoincrement())
  purchaseOrderId    Int
  catalogCigarId     Int
  lineNumber         Int
  quantity           Int
  unitPrice          Decimal
  lineSubtotal       Decimal
  msrpPerCigar       Decimal?
  receivedDate       DateTime?
  allocatedShipping  Decimal   @default(0)
  allocatedExciseTax Decimal   @default(0)
  allocatedSalesTax  Decimal   @default(0)
  allocatedDiscount  Decimal   @default(0)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  catalogCigar  CatalogCigar  @relation(fields: [catalogCigarId], references: [id])
  lot           Lot?

  @@unique([purchaseOrderId, lineNumber])
  @@index([purchaseOrderId])
  @@index([catalogCigarId])
  @@index([receivedDate])
}

model Lot {
  id                Int  @id @default(autoincrement())
  vitolaId          Int?
  storageLocationId Int?
  purchaseOrderId   Int?
  purchaseLineId    Int? @unique
  catalogCigarId    Int?

  quantityPurchased Int
  quantityRemaining Int
  originalQuantity  Int?
  currentQuantity   Int?

  msrpPerCigar          Decimal?
  actualCostPerCigar    Decimal?
  allocatedCostPerCigar Decimal?

  purchaseDate         DateTime?
  vendorIdSnapshot     Int?
  vendorNameSnapshot   String?
  purchaseDateSnapshot DateTime?
  receivedDateSnapshot DateTime?
  costPerCigarSnapshot Decimal?
  msrpPerCigarSnapshot Decimal?
  sourceSnapshot       String?
  boxCode              String?
  notes                String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  vitola          Vitola?          @relation(fields: [vitolaId], references: [id])
  storageLocation StorageLocation? @relation(fields: [storageLocationId], references: [id])
  purchaseOrder   PurchaseOrder?   @relation(fields: [purchaseOrderId], references: [id])
  purchaseLine    PurchaseLine?    @relation(fields: [purchaseLineId], references: [id])
  catalogCigar    CatalogCigar?    @relation(fields: [catalogCigarId], references: [id])

  events           InventoryEvent[]
  locationBalances LotLocationBalance[]

  @@index([catalogCigarId])
  @@index([purchaseDateSnapshot])
  @@index([receivedDateSnapshot])
  @@index([vendorIdSnapshot])
}

/// StorageSubLocation represents an addressable drawer, shelf, general area, or custom section inside a humidor.
model StorageSubLocation {
  id                Int                    @id @default(autoincrement())
  storageLocationId Int
  name              String
  kind              StorageSubLocationKind
  capacity          Int?
  displayOrder      Int                    @default(0)
  isActive          Boolean                @default(true)
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  storageLocation     StorageLocation      @relation(fields: [storageLocationId], references: [id])
  lotLocationBalances LotLocationBalance[]

  @@unique([storageLocationId, name])
  @@index([storageLocationId, isActive, displayOrder])
}

/// LotLocationBalance is a current-balance cache; inventory events remain the historical source of truth.
model LotLocationBalance {
  id                   Int      @id @default(autoincrement())
  lotId                Int
  storageSubLocationId Int
  quantity             Int
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  lot                Lot                @relation(fields: [lotId], references: [id])
  storageSubLocation StorageSubLocation @relation(fields: [storageSubLocationId], references: [id])

  @@unique([lotId, storageSubLocationId])
  @@index([lotId])
  @@index([storageSubLocationId])
}

model InventoryEvent {
  id        Int      @id @default(autoincrement())
  lotId     Int
  eventType String
  quantity  Int
  eventDate DateTime
  notes     String?

  costPerCigarAtEvent Decimal?
  msrpPerCigarAtEvent Decimal?

  createdAt DateTime @default(now())

  lot Lot @relation(fields: [lotId], references: [id])
}

/// Catalog records describe what a cigar is. They do not store quantity, cost basis, purchase history, or humidor location.
model CatalogCigar {
  id              Int      @id @default(autoincrement())
  manufacturer    String
  manufacturerKey String
  series          String
  seriesKey       String
  vitola          String
  vitolaKey       String
  shape           String?
  length          Decimal?
  ringGauge       Int?
  wrapper         String?
  wrapperKey      String?
  binder          String?
  filler          String?
  country         String?
  strength        String?
  msrp            Decimal?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  purchaseLines PurchaseLine[]
  lots          Lot[]

  @@unique([manufacturerKey, seriesKey, vitolaKey, wrapperKey])
  @@index([isActive, manufacturerKey, seriesKey, vitolaKey, wrapperKey])
}
